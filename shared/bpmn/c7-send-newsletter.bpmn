<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_180pfvm" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:process id="sendNewsletter" isExecutable="true">
    <bpmn:startEvent id="startEvent_editionCreated" name="Newsletter edition created">
      <bpmn:outgoing>Flow_0bianz5</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0bianz5" sourceRef="startEvent_editionCreated" targetRef="serviceTask_loadSubscribers" />
    <bpmn:serviceTask id="serviceTask_loadSubscribers" name="Load subscribers" camunda:type="external" camunda:topic="newsletter.loadSubscribers">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="subscribers">${subscribers}</camunda:outputParameter>
          <camunda:outputParameter name="author">${author}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bianz5</bpmn:incoming>
      <bpmn:outgoing>Flow_04andb8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_04andb8" sourceRef="serviceTask_loadSubscribers" targetRef="gateway_hasSubscribers" />
    <bpmn:serviceTask id="serviceTask_sendToSubscriber" name="Send to subscriber" camunda:type="external" camunda:topic="newsletter.sendMailToSubscriber">
      <bpmn:incoming>Flow_1jogut0</bpmn:incoming>
      <bpmn:outgoing>Flow_1ruayvl</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="true" camunda:collection="${subscribers}" camunda:elementVariable="subscriber" />
    </bpmn:serviceTask>
    <bpmn:endEvent id="endEvent_editionSent" name="Newsletter edition send">
      <bpmn:incoming>Flow_0v2v55n</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1ruayvl" sourceRef="serviceTask_sendToSubscriber" targetRef="serviceTask_notifyAuthor" />
    <bpmn:sequenceFlow id="Flow_0v2v55n" sourceRef="serviceTask_notifyAuthor" targetRef="endEvent_editionSent" />
    <bpmn:serviceTask id="serviceTask_notifyAuthor" name="Notify authors" camunda:type="external" camunda:topic="newsletter.notifyAuthor">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="test">null</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ruayvl</bpmn:incoming>
      <bpmn:outgoing>Flow_0v2v55n</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="${authors}" camunda:elementVariable="author" />
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_hasSubscribers" name="Has subscribers?" default="Flow_1jogut0">
      <bpmn:incoming>Flow_04andb8</bpmn:incoming>
      <bpmn:outgoing>Flow_1jogut0</bpmn:outgoing>
      <bpmn:outgoing>Flow_1gsz7wd</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1jogut0" name="Yes" sourceRef="gateway_hasSubscribers" targetRef="serviceTask_sendToSubscriber">
      <bpmn:extensionElements />
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="endEvent_noSubscribers" name="No subscribers found">
      <bpmn:incoming>Flow_1gsz7wd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1gsz7wd" name="No" sourceRef="gateway_hasSubscribers" targetRef="endEvent_noSubscribers">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${subscribers.size() &gt; 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:subProcess id="eventSubProcess_errorHandling" name="Error handling" triggeredByEvent="true">
      <bpmn:startEvent id="event_mailRejected" name="Mail rejected">
        <bpmn:outgoing>Flow_0vtppnk</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_12zsezj" messageRef="Message_3bq0n3s" />
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_0vtppnk" sourceRef="event_mailRejected" targetRef="serviceTask_analyzeError" />
      <bpmn:serviceTask id="serviceTask_analyzeError" name="Analyze error" camunda:type="external" camunda:topic="newsletter.analyzeSendError">
        <bpmn:incoming>Flow_0vtppnk</bpmn:incoming>
        <bpmn:outgoing>Flow_13nmnag</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:exclusiveGateway id="gateway_canSendAgain" name="Can re-send?" default="Flow_1izucof">
        <bpmn:incoming>Flow_13nmnag</bpmn:incoming>
        <bpmn:outgoing>Flow_1izucof</bpmn:outgoing>
        <bpmn:outgoing>Flow_18nf2jh</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_13nmnag" sourceRef="serviceTask_analyzeError" targetRef="gateway_canSendAgain" />
      <bpmn:sequenceFlow id="Flow_1izucof" name="Yes" sourceRef="gateway_canSendAgain" targetRef="serviceTask_sendMailAgain" />
      <bpmn:sequenceFlow id="Flow_0vym6nu" sourceRef="serviceTask_sendMailAgain" targetRef="eventGateway_afterSendingAgain" />
      <bpmn:eventBasedGateway id="eventGateway_afterSendingAgain">
        <bpmn:incoming>Flow_0vym6nu</bpmn:incoming>
        <bpmn:outgoing>Flow_0enjkoe</bpmn:outgoing>
        <bpmn:outgoing>Flow_081cykl</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:sequenceFlow id="Flow_18nf2jh" name="No" sourceRef="gateway_canSendAgain" targetRef="escalationEndEvent_nofitySupport">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${canBeResolved == false}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:serviceTask id="serviceTask_sendMailAgain" name="Send mail again" camunda:type="external" camunda:topic="newsletter.sendMailToSubscriber">
        <bpmn:incoming>Flow_1izucof</bpmn:incoming>
        <bpmn:outgoing>Flow_0vym6nu</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_0enjkoe" sourceRef="eventGateway_afterSendingAgain" targetRef="timer_noRejectionForOneDay" />
      <bpmn:intermediateCatchEvent id="timer_noRejectionForOneDay" name="No rejection for 1 day">
        <bpmn:incoming>Flow_0enjkoe</bpmn:incoming>
        <bpmn:outgoing>Flow_0338xzf</bpmn:outgoing>
        <bpmn:timerEventDefinition id="TimerEventDefinition_1w1lmdp">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1D</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:endEvent id="escalationEndEvent_nofitySupport" name="Notify support">
        <bpmn:incoming>Flow_18nf2jh</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0v78ov7" escalationRef="Escalation_2gr27c9" />
      </bpmn:endEvent>
      <bpmn:intermediateCatchEvent id="event_mailRejectedAgain" name="Mail rejected again">
        <bpmn:incoming>Flow_081cykl</bpmn:incoming>
        <bpmn:outgoing>Flow_0x9thpq</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_1wq8qup" messageRef="Message_0qejt6h" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_081cykl" sourceRef="eventGateway_afterSendingAgain" targetRef="event_mailRejectedAgain" />
      <bpmn:sequenceFlow id="Flow_0x9thpq" sourceRef="event_mailRejectedAgain" targetRef="escalationEndEvent_nofitySupportAfterRepeatedError" />
      <bpmn:endEvent id="escalationEndEvent_nofitySupportAfterRepeatedError" name="Notify support">
        <bpmn:incoming>Flow_0x9thpq</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0y07we7" escalationRef="Escalation_2gr27c9" />
      </bpmn:endEvent>
      <bpmn:endEvent id="endEvent_issueResolved" name="Temporary issue resolved">
        <bpmn:incoming>Flow_0338xzf</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0338xzf" sourceRef="timer_noRejectionForOneDay" targetRef="endEvent_issueResolved" />
    </bpmn:subProcess>
  </bpmn:process>
  <bpmn:escalation id="Escalation_2gr27c9" name="escalation_notifySupport" escalationCode="200" />
  <bpmn:message id="Message_0qejt6h" name="Message_MailRejectedAgain" />
  <bpmn:message id="Message_3bq0n3s" name="Message_MailRejected" />
