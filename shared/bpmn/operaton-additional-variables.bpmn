<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:message id="Message_1" name="Message_OrderReceived" />
  <bpmn:process id="orderProcess" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Order received">
      <bpmn:extensionElements>
        <operaton:properties>
          <operaton:property name="additionalOutputVariables" value="orderId, customerEmail, amount" />
        </operaton:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_1" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_ProcessOrder" name="Process order" operaton:delegateExpression="processOrderDelegate">
      <bpmn:extensionElements>
        <operaton:inputOutput>
          <operaton:inputParameter name="orderId">${orderId}</operaton:inputParameter>
          <operaton:outputParameter name="orderId">${orderId}</operaton:outputParameter>
        </operaton:inputOutput>
        <operaton:properties>
          <operaton:property name="additionalInputVariables" value="orderId" />
          <operaton:property name="additionalOutputVariables" value="shipmentId" />
        </operaton:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_OrderProcessed" name="Order processed">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_OrderReceived" targetRef="Activity_ProcessOrder" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_ProcessOrder" targetRef="EndEvent_OrderProcessed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="orderProcess">
      <bpmndi:BPMNShape id="Event_1_di" bpmnElement="StartEvent_OrderReceived">
        <dc:Bounds x="182" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1_di" bpmnElement="Activity_ProcessOrder">
        <dc:Bounds x="270" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_2_di" bpmnElement="EndEvent_OrderProcessed">
        <dc:Bounds x="422" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="218" y="120" />
        <di:waypoint x="270" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="370" y="120" />
        <di:waypoint x="422" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
